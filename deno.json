{
	"workspace": [
		"./version",
		"./global",
		"./signal",
		"./omni",
		"./omni-web",
		"./error",
		"./examples/*"
	],
	"tasks": {
		"ok": {
			"command": "deno task version && deno test && deno fmt && deno lint --fix",
			"description": "Get ready to commit"
		},
		"commit": {
			"command": "deno task ok && git add . && git commit",
			"description": "A commit helper"
		},
		"version": {
			"command": "deno run -A @beo/version",
			"description": "Update the versions of all packages"
		},
		"change": {
			"command": "deno run -A @beo/version --add",
			"description": "Adds a changelog entry"
		},
		"release": {
			"command": "deno run -A @beo/version --release && deno task ok && git add . && git commit -m \"chore: release\" && git push",
			"description": "Bumps all package versions"
		},
		"basic:dev": {
			"command": "deno task --cwd=./examples/basic dev",
			"description": "Run the basic application"
		}
	},
	"fmt": {
		"useTabs": true,
		"semiColons": false
	},
	"lint": {
		"rules": {
			"exclude": [
				"no-explicit-any"
			]
		}
	},
	"imports": {
		"@std/assert": "jsr:@std/assert@^1.0.19"
	}
}
